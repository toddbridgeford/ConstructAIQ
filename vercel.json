{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "next dev",
  "crons": [
    {
      "path": "/api/cron/harvest",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/forecast",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/federal",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/brief",
      "schedule": "0 12 * * 1"
    }
  ]
}

{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "devCommand": "next dev",
  "crons": [
    {
      "path": "/api/cron/push-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/opportunity-scores",
      "schedule": "30 9 * * *"
    }
  ]
}

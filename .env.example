# ── Supabase ────────────────────────────────────────────────────────────────
# Required. Get these from your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── External Data APIs ───────────────────────────────────────────────────────
# FRED / St. Louis Fed — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Census Bureau — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Bureau of Labor Statistics — https://www.bls.gov/developers/
BLS_API_KEY=

# Bureau of Economic Analysis — https://apps.bea.gov/api/signup/
BEA_API_KEY=

# Energy Information Administration — https://www.eia.gov/opendata/
EIA_API_KEY=

# ── Rate Limiting (Redis) ─────────────────────────────────────────────────
# Optional. When set, enables real per-key RPM + RPD enforcement via Upstash.
# Create a free database at https://upstash.com — copy REST URL and token.
# Without these, rate limits are stored in DB but not enforced in real time.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Cron Job Security ────────────────────────────────────────────────────────
# Protects /api/cron/* endpoints AND /api/keys/issue POST (key provisioning).
# Set to a long random string (e.g. openssl rand -hex 32).
# Pass as Authorization: Bearer <secret> when calling from Vercel cron or admin scripts.
CRON_SECRET=

# ── Error Monitoring (Sentry) ────────────────────────────────────────────────
# Optional. Get from https://sentry.io → Project → Settings → Client Keys.
# Without this, Sentry is silently disabled (no crash at startup).
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=constructaiq

# ── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://constructaiq.trade

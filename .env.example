# ── Supabase ────────────────────────────────────────────────────────────────
# Required. Get these from your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── External Data APIs ───────────────────────────────────────────────────────
# FRED / St. Louis Fed — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Census Bureau — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Bureau of Labor Statistics — https://www.bls.gov/developers/
BLS_API_KEY=

# Bureau of Economic Analysis — https://apps.bea.gov/api/signup/
BEA_API_KEY=

# Energy Information Administration — https://www.eia.gov/opendata/
EIA_API_KEY=

# SAM.gov — Active federal solicitations / bid opportunities (NAICS 236/237/238)
# Free registration: https://sam.gov/content/entity-registration
# Without this, solicitations array is returned empty — not a fatal error.
SAM_GOV_API_KEY=

# Copernicus Data Space — Sentinel-2 satellite imagery for BSI pipeline
# Free registration: https://dataspace.copernicus.eu
# OAuth2 client credentials: Dashboard → User Settings → OAuth Clients → New Client
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=

# ── GitHub Actions ───────────────────────────────────────────────────────────
# Required only to trigger the satellite pipeline manually via /api/satellite/trigger.
# Create at: github.com/settings/tokens → Fine-grained → Actions: write
GITHUB_TOKEN=

# ── Rate Limiting (Redis) ─────────────────────────────────────────────────
# Optional. When set, enables real per-key RPM + RPD enforcement via Upstash.
# Create a free database at https://upstash.com — copy REST URL and token.
# Without these, rate limits are stored in DB but not enforced in real time.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── Cron Job Security ────────────────────────────────────────────────────────
# Protects /api/cron/* endpoints AND /api/keys/issue POST (key provisioning).
# Set to a long random string (e.g. openssl rand -hex 32).
# Pass as Authorization: Bearer <secret> when calling from Vercel cron or admin scripts.
CRON_SECRET=

# ── Error Monitoring (Sentry) ────────────────────────────────────────────────
# Optional. Get from https://sentry.io → Project → Settings → Client Keys.
# Without this, Sentry is silently disabled (no crash at startup).
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=constructaiq

# ── Claude AI (weekly brief generation) ──────────────────────────────────────
# Required for AI-powered weekly intelligence briefs.
# Without this key the route falls back to static content.
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate once with: node -e "require('web-push').generateVAPIDKeys()"
# NEXT_PUBLIC_ key is safe to expose in the browser (part of VAPID protocol).
# VAPID_PRIVATE_KEY must stay secret — never commit it.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=  # From: node -e "require('web-push').generateVAPIDKeys()"
VAPID_PRIVATE_KEY=             # From same command — keep secret, never commit
VAPID_SUBJECT=mailto:hello@constructaiq.trade

# ── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://constructaiq.trade

# ── Pre-launch lockdown ───────────────────────────────────────────────────────
# Set SITE_LOCKED=true to password-protect all pages (HTTP Basic Auth).
# Remove or set to false when ready to go public.
SITE_LOCKED=true
SITE_USER=admin
SITE_PASS=ConstructAIQ2026!
